{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gettext PO",
  "scopeName": "source.po",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.flag.po",
          "match": "^(#,)(.*)$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.po" },
            "2": {
              "patterns": [
                {
                  "name": "invalid.deprecated.flag.fuzzy.po",
                  "match": "\\bfuzzy\\b"
                },
                {
                  "name": "keyword.other.flag.format.po",
                  "match": "\\b[a-z0-9-]+-format\\b"
                },
                {
                  "name": "keyword.other.flag.po",
                  "match": "\\b[a-z0-9-]+\\b"
                }
              ]
            }
          }
        },
        {
          "name": "comment.line.number-sign.reference.po",
          "match": "^(#:)(.*)$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.po" },
            "2": {
              "patterns": [
                {
                  "name": "markup.underline.link.reference.po",
                  "match": "[^\\s:]+(?=:\\d+)"
                },
                {
                  "name": "constant.numeric.line.po",
                  "match": "(?<=:)\\d+"
                }
              ]
            }
          }
        },
        {
          "name": "comment.line.number-sign.previous.po",
          "begin": "^(#\\|)",
          "end": "$",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.comment.po" }
          },
          "patterns": [
            {
              "name": "keyword.control.previous.po",
              "match": "\\b(msgid|msgid_plural|msgctxt|msgstr)\\b"
            },
            { "include": "#strings" }
          ]
        },
        {
          "name": "comment.line.number-sign.extracted.po",
          "match": "^(#\\.)(.*)$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.po" }
          }
        },
        {
          "name": "comment.line.number-sign.translator.po",
          "match": "^(#)(?![.,:|])(.*)$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.po" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.msgid-plural.po",
          "match": "^\\s*\\bmsgid_plural\\b"
        },
        {
          "name": "keyword.control.context.po",
          "match": "^\\s*\\bmsgctxt\\b"
        },
        {
          "name": "keyword.control.msgid.po",
          "match": "^\\s*\\bmsgid\\b"
        },
        {
          "match": "^\\s*(msgstr)(\\[)(\\d+)(\\])",
          "captures": {
            "1": { "name": "keyword.control.msgstr.po" },
            "2": { "name": "punctuation.definition.index.po" },
            "3": { "name": "constant.numeric.plural-index.po" },
            "4": { "name": "punctuation.definition.index.po" }
          }
        },
        {
          "name": "keyword.control.msgstr.po",
          "match": "^\\s*\\bmsgstr\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.po",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.po" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.po" }
      },
      "patterns": [
        { "include": "#html-tag" },
        { "include": "#html-entity" },
        { "include": "#escapes" },
        { "include": "#placeholders" }
      ]
    },
    "html-tag": {
      "comment": "Matches a whole HTML/XML tag on a single line so it can never bleed past the closing PO quote.",
      "match": "(</?)([a-zA-Z][a-zA-Z0-9:_.-]*)((?:[^>])*?)(/?>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.begin.po" },
        "2": { "name": "entity.name.tag.po" },
        "3": {
          "patterns": [
            {
              "name": "entity.other.attribute-name.po",
              "match": "[a-zA-Z_:][a-zA-Z0-9_:.-]*(?=\\s*=)"
            },
            { "include": "#escapes" },
            { "include": "#html-entity" },
            { "include": "#placeholders" },
            {
              "name": "string.unquoted.attribute-value.po",
              "match": "[^\\s=\"\\\\]+"
            }
          ]
        },
        "4": { "name": "punctuation.definition.tag.end.po" }
      }
    },
    "html-entity": {
      "name": "constant.character.entity.html.po",
      "match": "&(?:[a-zA-Z][a-zA-Z0-9]*|#[0-9]+|#[xX][0-9A-Fa-f]+);"
    },
    "escapes": {
      "name": "constant.character.escape.po",
      "match": "\\\\(?:[abfnrtv\\\\\"]|[0-7]{1,3}|x[0-9A-Fa-f]+|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})"
    },
    "placeholders": {
      "patterns": [
        {
          "name": "variable.parameter.placeholder.named.po",
          "match": "%\\([^)]*\\)[-+ #0-9.*hlLqjzt]*[diouxXeEfFgGcrsab%]"
        },
        {
          "name": "variable.parameter.placeholder.printf.po",
          "match": "%[-+ #0-9.*hlLqjzt]*[diouxXeEfFgGcrsab%]"
        },
        {
          "name": "variable.parameter.placeholder.brace.po",
          "match": "\\{[^{}]*\\}"
        }
      ]
    }
  }
}
